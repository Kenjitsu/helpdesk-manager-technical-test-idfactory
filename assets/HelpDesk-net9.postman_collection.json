      "name": "Auth",
      "item": [
        {
          "name": "login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Access token exists\", function () {\r",
                  "    pm.expect(response.data.accessToken).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.globals.set('token', response.data.accessToken);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"admin@test.com\",\r\n  \"password\": \"Pa$$w0rd\"\r\n}",
